generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum CommunityVisibility {
  public
  private
}

enum CommunityRole {
  member
  moderator
  admin
}

enum DeviceType {
  mobile
  tablet
  desktop
  unknown
}

enum ActivityAction {
  login
  logout
  post_create
  post_delete
  follow
  react
  suspicious_login
}

model User {
  id              String            @id @default(uuid()) @db.VarChar(36)
  username        String            @unique @db.VarChar(50)
  email           String            @unique @db.VarChar(255)
  password_hash   String            @db.VarChar(255)
  is_verified     Boolean           @default(false)
  is_private      Boolean           @default(false)
  is_active       Boolean           @default(true)
  follower_count  Int               @default(0)
  following_count Int               @default(0)
  created_at      DateTime          @default(now()) @db.Timestamp(0)
  updated_at      DateTime          @default(now()) @updatedAt @db.Timestamp(0)

  UserProfile      UserProfile?
  CommunitiesOwned Community[]       @relation("CommunityOwner")
  CommunityMembers CommunityMember[]
  Sessions         Session[]
  Devices          Device[]
  Locations        Location[]
  ActivityLogs     ActivityLog[]

  @@map("users")
}

model UserProfile {
  id           String    @id @default(uuid()) @db.VarChar(36)
  user_id      String    @unique @db.VarChar(36)
  display_name String?   @db.VarChar(100)
  bio          String?   @db.Text
  avatar_url   String?   @db.VarChar(500)
  banner_url   String?   @db.VarChar(500)
  website      String?   @db.VarChar(255)
  location     String?   @db.VarChar(100)
  birth_date   DateTime? @db.Date
  gender       Gender?
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  User User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Community {
  id           String              @id @default(uuid()) @db.VarChar(36)
  owner_id     String              @db.VarChar(36)
  name         String              @db.VarChar(100)
  slug         String              @unique @db.VarChar(100)
  description  String?             @db.Text
  avatar_url   String?             @db.VarChar(500)
  banner_url   String?             @db.VarChar(500)
  visibility   CommunityVisibility @default(public)
  member_count Int                 @default(0)
  post_count   Int                 @default(0)
  created_at   DateTime            @default(now()) @db.Timestamp(0)
  updated_at   DateTime            @default(now()) @updatedAt @db.Timestamp(0)

  Owner   User              @relation("CommunityOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  Members CommunityMember[]

  @@map("communities")
}

model CommunityMember {
  id           String        @id @default(uuid()) @db.VarChar(36)
  user_id      String        @db.VarChar(36)
  community_id String        @db.VarChar(36)
  role         CommunityRole @default(member)
  joined_at    DateTime      @default(now()) @db.Timestamp(0)

  User      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Community Community @relation(fields: [community_id], references: [id], onDelete: Cascade)

  @@unique([user_id, community_id])
  @@map("community_members")
}

model Session {
  id             String    @id @default(uuid()) @db.VarChar(36)
  user_id        String    @db.VarChar(36)
  token          String    @unique @db.VarChar(500)
  device_id      String?   @db.VarChar(36)
  ip_address     String?   @db.VarChar(45)
  is_active      Boolean   @default(true)
  expires_at     DateTime  @db.Timestamp(0)
  last_active_at DateTime  @default(now()) @db.Timestamp(0)
  created_at     DateTime  @default(now()) @db.Timestamp(0)

  User     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Device   Device?   @relation(fields: [device_id], references: [id], onDelete: SetNull)
  Locations Location[]
  ActivityLogs ActivityLog[]

  @@map("sessions")
}

model Device {
  id            String     @id @default(uuid()) @db.VarChar(36)
  user_id       String     @db.VarChar(36)
  device_name   String?    @db.VarChar(100)
  device_type   DeviceType @default(unknown)
  os            String?    @db.VarChar(50)
  browser       String?    @db.VarChar(50)
  push_token    String?    @db.VarChar(500)
  is_trusted    Boolean    @default(false)
  last_login_at DateTime   @default(now()) @db.Timestamp(0)
  created_at    DateTime   @default(now()) @db.Timestamp(0)

  User      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Sessions  Session[]

  @@map("devices")
}

model Location {
  id            String   @id @default(uuid()) @db.VarChar(36)
  session_id    String   @db.VarChar(36)
  user_id       String   @db.VarChar(36)
  ip_address    String   @db.VarChar(45)
  country       String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  is_suspicious Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamp(0)

  Session Session @relation(fields: [session_id], references: [id], onDelete: Cascade)
  User    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("locations")
}

model ActivityLog {
  id           String         @id @default(uuid()) @db.VarChar(36)
  user_id      String         @db.VarChar(36)
  session_id   String?        @db.VarChar(36)
  action       ActivityAction
  content_type String?        @db.VarChar(50)
  content_id   String?        @db.VarChar(36)
  metadata     Json?
  ip_address   String?        @db.VarChar(45)
  created_at   DateTime       @default(now()) @db.Timestamp(0)

  User    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  Session Session? @relation(fields: [session_id], references: [id], onDelete: SetNull)

  @@index([created_at])
  @@map("activity_logs")
}
